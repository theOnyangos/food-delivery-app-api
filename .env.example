APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# API (Laravel); do not use this for SPA links in emails — set CLIENT_URL below.
APP_URL=http://localhost
# Dashboard SPA origin — required for correct password-reset / invite links (no trailing slash).
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
FRONTEND_LOGIN_URL=http://localhost:3000/login
SUPER_ADMIN_EMAIL=admin@asl.local
SUPER_ADMIN_PASSWORD=SuperAdmin123!

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=asl_api
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Use reverb for WebSockets; Echo subscribes to private channel private-chat.conversation.{uuid} (see routes/channels.php).
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

REVERB_APP_ID=local-app
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# OpenAI / AI Agent (see config/ai_agent.php)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_ASSISTANT_ID=
AI_AGENT_ENABLED=true
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.7
AI_MAX_HISTORY_MESSAGES=10
AI_RATE_LIMIT_PER_USER=30
AI_RATE_LIMIT_PER_IP=60
AI_DAILY_LIMIT_CUSTOMER=5
AI_DAILY_LIMIT_ADMIN=0
AI_DAILY_LIMIT_PARTNER=0
